{
  "schema_id": "https://nexus-lab-test-bed.local/schemas/scenario-manifest.schema.json",
  "scenario_id": "maintenance-outage-handling",
  "version": "v1-0-0",
  "title": "Maintenance outage handling",
  "objective": "Validate production and maintenance coordination under bounded execution.",
  "actors_in_scope": [
    "maintenance-lead",
    "production-coordinator",
    "service-vanguard",
    "service-nexus",
    "worker-scenario-runner-v1"
  ],
  "models_in_scope": [
    "ollama-llama3_2-laptop"
  ],
  "policies_in_scope": [
    "allow-fake-company-local-inference",
    "allow-ops-logistics-execution",
    "finance-execution-requires-approval",
    "allow-bounded-worker-registry-and-log-writes"
  ],
  "inputs": {
    "maintenance_ticket": "MNT-5001",
    "asset_code": "PACKLINE-01",
    "data_class": "restricted"
  },
  "steps": [
    {
      "step_id": "load-maintenance-context",
      "kind": "registry_load",
      "actor_id": "worker-scenario-runner-v1",
      "requested_capability": "scenario.run",
      "input_ref": "inputs.maintenance_ticket",
      "expected_outcome": {
        "decision": "allow",
        "reason_contains": [
          "allow"
        ]
      }
    },
    {
      "step_id": "maintenance-summary",
      "kind": "inference_request",
      "actor_id": "maintenance-lead",
      "requested_capability": "inference.request",
      "model_id": "ollama-llama3_2-laptop",
      "input_ref": "inputs.asset_code",
      "expected_outcome": {
        "decision": "allow",
        "reason_contains": [
          "allow",
          "local"
        ]
      }
    },
    {
      "step_id": "production-reschedule",
      "kind": "execution_request",
      "actor_id": "production-coordinator",
      "requested_capability": "execution.request",
      "input_ref": "inputs.maintenance_ticket",
      "expected_outcome": {
        "decision": "allow",
        "reason_contains": [
          "allow"
        ]
      }
    }
  ],
  "success_conditions": [
    "Maintenance summary is allowed locally.",
    "Production reschedule request follows bounded internal execution."
  ]
}
