{
  "schema_id": "https://nexus-lab-test-bed.local/schemas/scenario-manifest.schema.json",
  "scenario_id": "shipping-delay-escalation",
  "version": "v1-0-0",
  "title": "Shipping delay escalation",
  "objective": "Validate logistics escalation flow for shipment delay communication.",
  "actors_in_scope": [
    "shipping-coordinator",
    "ops-manager",
    "service-vanguard",
    "service-nexus",
    "worker-scenario-runner-v1"
  ],
  "models_in_scope": ["ollama-llama3_2-laptop"],
  "policies_in_scope": [
    "allow-fake-company-local-inference",
    "allow-ops-logistics-execution",
    "finance-execution-requires-approval",
    "allow-bounded-worker-registry-and-log-writes"
  ],
  "inputs": {
    "shipment_code": "SHIP-7001",
    "call_log": "CALL-4201",
    "data_class": "confidential"
  },
  "steps": [
    {
      "step_id": "load-logistics-context",
      "kind": "registry_load",
      "actor_id": "worker-scenario-runner-v1",
      "requested_capability": "scenario.run",
      "input_ref": "inputs.shipment_code",
      "expected_outcome": {
        "decision": "allow",
        "reason_contains": ["allow"]
      }
    },
    {
      "step_id": "shipping-summary",
      "kind": "inference_request",
      "actor_id": "shipping-coordinator",
      "requested_capability": "inference.request",
      "model_id": "ollama-llama3_2-laptop",
      "input_ref": "inputs.call_log",
      "expected_outcome": {
        "decision": "allow",
        "reason_contains": ["allow", "local"]
      }
    },
    {
      "step_id": "ops-bounded-execution",
      "kind": "execution_request",
      "actor_id": "ops-manager",
      "requested_capability": "execution.request",
      "input_ref": "inputs.shipment_code",
      "expected_outcome": {
        "decision": "allow",
        "reason_contains": ["allow"]
      }
    }
  ],
  "success_conditions": [
    "Shipping summary is allowed locally.",
    "Ops execution path is allowed for internal logistics action."
  ]
}
