    {
      "generator_id": "governance-pressure",
      "family": "governance-pressure",
      "supported_stages": ["regional_midmarket", "multi_region_enterprise"],
      "default_cadence": "weekly-core",
      "outputs": ["approval_delay", "policy_exception", "shadow_ai_signal"],
