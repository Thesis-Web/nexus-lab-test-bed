        "small_local",
        "multi_site_small",
        "regional_midmarket",
        "multi_region_enterprise"
      ],
      "default_cadence": "daily-core",
      "outputs": ["requisition", "po", "approval"],
      "deterministic_notes": "office-supplies and parts requests scale by stage"
    },
    {
      "generator_id": "finance-inbox",
      "family": "finance",
      "supported_stages": [
        "small_local",
        "multi_site_small",
        "regional_midmarket",
        "multi_region_enterprise"
      ],
      "default_cadence": "daily-core",
      "outputs": ["invoice", "payment_state", "journal"],
