{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/schemas/simulation-clock-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_id",
    "version",
    "timezone",
    "business_week",
    "business_day",
    "tick_profiles",
    "stage_cadence_multipliers"
  ],
  "properties": {
    "registry_id": {
      "const": "simulation-clock"
    },
    "version": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/version"
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "business_week": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "monday",
          "tuesday",
          "wednesday",
          "thursday",
          "friday",
          "saturday",
          "sunday"
        ]
      }
    },
    "business_day": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_local", "end_local"],
      "properties": {
        "start_local": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "end_local": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        }
      }
    },
    "tick_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tick_id", "unit", "interval", "used_for"],
        "properties": {
          "tick_id": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/simulation-common.schema.json#/$defs/tickId"
          },
          "unit": {
            "type": "string",
            "enum": ["minute", "hour", "day", "week", "month", "quarter"]
          },
          "interval": {
            "type": "integer",
            "minimum": 1
          },
          "used_for": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/simulation-common.schema.json#/$defs/stringArray"
          }
        }
      }
    },
    "stage_cadence_multipliers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "small_local",
        "multi_site_small",
        "regional_midmarket",
        "multi_region_enterprise"
      ],
      "properties": {
        "small_local": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "multi_site_small": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "regional_midmarket": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "multi_region_enterprise": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
