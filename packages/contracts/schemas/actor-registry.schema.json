{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/schemas/actor-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "registry_id", "version", "generated_at", "actors"],
  "properties": {
    "schema_id": {
      "const": "https://nexus-lab-test-bed.local/schemas/actor-registry.schema.json"
    },
    "registry_id": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/slug"
    },
    "version": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/version"
    },
    "generated_at": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/timestamp"
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actor_id",
          "actor_type",
          "display_name",
          "auth_source",
          "capability_ceiling",
          "data_access",
          "environment_bindings",
          "enabled"
        ],
        "properties": {
          "actor_id": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/slug"
          },
          "actor_type": {
            "type": "string",
            "enum": ["human", "service", "worker", "system"]
          },
          "display_name": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/nonEmptyString"
          },
          "auth_source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "subject"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["upstream_rbac", "local_static", "service_principal"]
              },
              "subject": {
                "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/nonEmptyString"
              }
            }
          },
          "capability_ceiling": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/capability"
            }
          },
          "data_access": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "max_data_class",
              "allow_filesystem_read",
              "allow_filesystem_write",
              "allow_network_egress"
            ],
            "properties": {
              "max_data_class": {
                "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/dataClass"
              },
              "allow_filesystem_read": {
                "type": "boolean"
              },
              "allow_filesystem_write": {
                "type": "boolean"
              },
              "allow_network_egress": {
                "type": "boolean"
              }
            }
          },
          "environment_bindings": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["big-machine", "small-laptop-ollama", "droplet-git-only"]
            }
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
