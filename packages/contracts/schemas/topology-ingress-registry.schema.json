{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/schemas/topology-ingress-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "registry_id",
    "version",
    "generated_at",
    "ingress_points"
  ],
  "properties": {
    "schema_id": {
      "const": "https://nexus-lab-test-bed.local/schemas/topology-ingress-registry.schema.json"
    },
    "registry_id": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/slug"
    },
    "version": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/version"
    },
    "generated_at": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/timestamp"
    },
    "ingress_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ingress_id",
          "title",
          "channel_type",
          "landing_system_id",
          "default_data_zone",
          "evidence_required"
        ],
        "properties": {
          "ingress_id": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/slug"
          },
          "title": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/nonEmptyString"
          },
          "channel_type": {
            "type": "string",
            "enum": [
              "email",
              "chat",
              "ticket",
              "calendar",
              "doc",
              "sheet",
              "erp_event",
              "local_workbook",
              "github_issue",
              "github_action"
            ]
          },
          "landing_system_id": {
            "type": "string",
            "minLength": 1
          },
          "default_data_zone": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/slug"
          },
          "evidence_required": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
