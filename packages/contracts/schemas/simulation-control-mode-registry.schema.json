{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/schemas/simulation-control-mode-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_id", "version", "modes"],
  "properties": {
    "registry_id": {
      "const": "simulation-control-modes"
    },
    "version": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/version"
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode_id", "description"],
        "properties": {
          "mode_id": {
            "type": "string",
            "enum": [
              "continuous",
              "paused",
              "snapshot",
              "reset",
              "rewind",
              "forked_timeline"
            ]
          },
          "description": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/simulation-common.schema.json#/$defs/nonEmptyString"
          }
        }
      }
    }
  }
}
