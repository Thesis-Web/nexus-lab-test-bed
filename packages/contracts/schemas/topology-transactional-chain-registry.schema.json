{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/schemas/topology-transactional-chain-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "registry_id",
    "version",
    "generated_at",
    "transactional_chains"
  ],
  "properties": {
    "schema_id": {
      "const": "https://nexus-lab-test-bed.local/schemas/topology-transactional-chain-registry.schema.json"
    },
    "registry_id": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/slug"
    },
    "version": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/version"
    },
    "generated_at": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/timestamp"
    },
    "transactional_chains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chain_id",
          "title",
          "objective",
          "ingress_ids",
          "systems_involved",
          "actor_roles",
          "state_objects",
          "approval_points",
          "local_only_steps",
          "outcome_types"
        ],
        "properties": {
          "chain_id": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/slug"
          },
          "title": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/nonEmptyString"
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "ingress_ids": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/stringArray"
          },
          "systems_involved": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/stringArray"
          },
          "actor_roles": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/stringArray"
          },
          "state_objects": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/stringArray"
          },
          "approval_points": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "local_only_steps": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "outcome_types": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/topology-common.schema.json#/$defs/stringArray"
          }
        }
      }
    }
  }
}
