{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/schemas/scenario-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "scenario_id",
    "version",
    "title",
    "objective",
    "actors_in_scope",
    "models_in_scope",
    "policies_in_scope",
    "inputs",
    "steps",
    "success_conditions"
  ],
  "properties": {
    "schema_id": {
      "const": "https://nexus-lab-test-bed.local/schemas/scenario-manifest.schema.json"
    },
    "scenario_id": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/slug"
    },
    "version": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/version"
    },
    "title": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/nonEmptyString"
    },
    "objective": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/nonEmptyString"
    },
    "actors_in_scope": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/stringArray"
    },
    "models_in_scope": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/stringArray"
    },
    "policies_in_scope": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/stringArray"
    },
    "inputs": {
      "type": "object"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "kind",
          "actor_id",
          "requested_capability",
          "input_ref",
          "expected_outcome"
        ],
        "properties": {
          "step_id": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/slug"
          },
          "kind": {
            "type": "string",
            "enum": [
              "registry_load",
              "inference_request",
              "execution_request",
              "assertion"
            ]
          },
          "actor_id": {
            "type": "string",
            "minLength": 1
          },
          "requested_capability": {
            "type": "string",
            "minLength": 1
          },
          "model_id": {
            "type": "string"
          },
          "input_ref": {
            "type": "string",
            "minLength": 1
          },
          "expected_outcome": {
            "type": "object",
            "additionalProperties": false,
            "required": ["decision", "reason_contains"],
            "properties": {
              "decision": {
                "type": "string",
                "enum": ["allow", "deny", "require_approval"]
              },
              "reason_contains": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "success_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
