{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/schemas/model-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "registry_id", "version", "generated_at", "models"],
  "properties": {
    "schema_id": {
      "const": "https://nexus-lab-test-bed.local/schemas/model-registry.schema.json"
    },
    "registry_id": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/slug"
    },
    "version": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/version"
    },
    "generated_at": {
      "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/timestamp"
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "model_id",
          "display_name",
          "provider",
          "locality",
          "transport",
          "policy_tags",
          "enabled"
        ],
        "properties": {
          "model_id": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/slug"
          },
          "display_name": {
            "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/nonEmptyString"
          },
          "provider": {
            "type": "string",
            "enum": ["ollama", "local_openai_compatible", "placeholder_remote"]
          },
          "locality": {
            "type": "string",
            "enum": ["big-machine", "small-laptop-ollama", "placeholder_remote"]
          },
          "transport": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "protocol",
              "base_url_env",
              "model_name",
              "timeout_ms"
            ],
            "properties": {
              "protocol": {
                "type": "string",
                "enum": ["ollama", "openai_compatible", "placeholder"]
              },
              "base_url_env": {
                "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/nonEmptyString"
              },
              "model_name": {
                "$ref": "https://nexus-lab-test-bed.local/schemas/common.schema.json#/$defs/nonEmptyString"
              },
              "timeout_ms": {
                "type": "integer",
                "minimum": 1000
              }
            }
          },
          "policy_tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
