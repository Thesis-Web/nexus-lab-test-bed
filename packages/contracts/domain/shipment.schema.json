{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/contracts/domain/shipment.schema.json",
  "title": "shipment",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "shipment_code": {
        "$ref": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json#/$defs/code"
      },
      "so_code": {
        "$ref": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json#/$defs/code"
      },
      "ship_from_location_code": {
        "$ref": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json#/$defs/code"
      },
      "ship_to_name": {
        "type": "string",
        "minLength": 1
      },
      "carrier": {
        "type": "string",
        "minLength": 1
      },
      "tracking_number": {
        "type": "string",
        "minLength": 1
      },
      "shipped_at": {
        "$ref": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json#/$defs/datetime"
      },
      "status": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "shipment_code",
      "so_code",
      "ship_from_location_code",
      "ship_to_name",
      "carrier",
      "tracking_number",
      "shipped_at",
      "status"
    ]
  }
}
