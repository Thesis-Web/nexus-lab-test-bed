{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json",
  "$defs": {
    "code": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9-]*$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "datetime": {
      "type": "string",
      "format": "date-time"
    },
    "money": {
      "type": "number"
    },
    "quantity": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "yesno": {
      "type": "boolean"
    }
  }
}
