{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/contracts/domain/journal-entry-line.schema.json",
  "title": "journal-entry-line",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "journal_entry_code": {
        "$ref": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json#/$defs/code"
      },
      "line_number": {
        "type": "integer",
        "minimum": 1
      },
      "account_code": {
        "type": "string",
        "pattern": "^[0-9]{4}$"
      },
      "entry_type": {
        "type": "string",
        "enum": ["debit", "credit"]
      },
      "amount": {
        "$ref": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json#/$defs/money"
      },
      "description": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "journal_entry_code",
      "line_number",
      "account_code",
      "entry_type",
      "amount",
      "description"
    ]
  }
}
