{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/contracts/domain/product.schema.json",
  "title": "product",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "sku": {
        "type": "string",
        "pattern": "^[A-Z0-9][A-Z0-9-]*$"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      },
      "product_family": {
        "type": "string",
        "minLength": 1
      },
      "unit_of_measure": {
        "type": "string",
        "minLength": 1
      },
      "default_location_code": {
        "$ref": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json#/$defs/code"
      }
    },
    "required": [
      "sku",
      "name",
      "product_family",
      "unit_of_measure",
      "default_location_code"
    ]
  }
}
