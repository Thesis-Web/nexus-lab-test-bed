{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-lab-test-bed.local/contracts/domain/location.schema.json",
  "title": "location",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "code": {
        "$ref": "https://nexus-lab-test-bed.local/contracts/domain/domain-common.schema.json#/$defs/code"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      },
      "address_line1": {
        "type": ["string", "null"]
      },
      "address_line2": {
        "type": ["string", "null"]
      },
      "city": {
        "type": "string"
      },
      "state": {
        "type": "string"
      },
      "postal_code": {
        "type": "string"
      },
      "country": {
        "type": "string"
      },
      "latitude": {
        "type": "number"
      },
      "longitude": {
        "type": "number"
      },
      "location_type": {
        "type": "string",
        "enum": ["plant", "warehouse", "office", "remote"]
      },
      "is_active": {
        "type": "boolean"
      }
    },
    "required": [
      "code",
      "name",
      "city",
      "state",
      "postal_code",
      "country",
      "latitude",
      "longitude",
      "location_type",
      "is_active"
    ]
  }
}
