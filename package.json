{
  "name": "nexus-lab-test-bed",
  "private": true,
  "version": "0.1.1",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "schema:validate": "node ./scripts/validate/validate-manifests.mjs",
    "lab:up": "bash ./scripts/local/bring-up.sh",
    "lab:down": "bash ./scripts/local/down.sh",
    "seed:registries": "node ./scripts/seed/load-registry-bundles.mjs",
    "seed:domain": "node ./scripts/seed/load-domain-seeds.mjs",
    "seed:all": "node ./scripts/seed/load-all.mjs"
  },
  "dependencies": {
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "glob": "^11.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
